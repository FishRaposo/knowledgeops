# KnowledgeOps Environment Variables
# Copy this file to .env and customize for your environment

# ─── General ───────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=knowledgeops
ENVIRONMENT=development

# ─── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql://knowledgeops:knowledgeops@db:5432/knowledgeops
POSTGRES_USER=knowledgeops
POSTGRES_PASSWORD=knowledgeops
POSTGRES_DB=knowledgeops

# ─── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Auth ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ─── LLM Providers ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
LLM_DEFAULT_PROVIDER=openai
LLM_DEFAULT_MODEL=gpt-4o-mini
LLM_EMBEDDING_MODEL=text-embedding-3-small
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# ─── LLM Gateway ──────────────────────────────────────────────────
LLM_GATEWAY_PORT=8004
LLM_CACHE_TTL_SECONDS=3600
LLM_BUDGET_DEFAULT_MONTHLY=100.00

# ─── Service Ports ────────────────────────────────────────────────
API_GATEWAY_PORT=8000
AUTH_SERVICE_PORT=8001
INGESTION_SERVICE_PORT=8002
RETRIEVAL_SERVICE_PORT=8003
EVAL_SERVICE_PORT=8005
TRACE_SERVICE_PORT=8006
WEB_APP_PORT=3000

# ─── Local Demo Auth ───────────────────────────────────────────────
# Set ALLOW_DEV_AUTH=true only for local demos.
ALLOW_DEV_AUTH=false
DEMO_TOKEN=dev-admin-token
NEXT_PUBLIC_DEMO_TOKEN=
COST_BUDGET_LIMIT_USD=100.00
BUDGET_ALERT_LIMIT_USD=100.00

# ─── Nginx ─────────────────────────────────────────────────────────
NGINX_PORT=80

# ─── Ingestion ─────────────────────────────────────────────────────
INGESTION_CHUNK_SIZE=512
INGESTION_CHUNK_OVERLAP=64
INGESTION_MAX_FILE_SIZE_MB=50

# ─── Retrieval ─────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_RERANK_TOP_K=3
RETRIEVAL_SIMILARITY_THRESHOLD=0.7

# ─── Eval ───────────────────────────────────────────────────────────
EVAL_SEMANTIC_THRESHOLD=0.8
EVAL_CITATION_STRICT=True

# ─── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
